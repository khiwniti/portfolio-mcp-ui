{
  "name": "portfolio-mcp-ui",
  "type": "module",
  "version": "1.0.0",
  "description": "MCP server: portfolio-mcp-ui",
  "author": "",
  "license": "MIT",
  "keywords": [
    "mcp",
    "server",
    "blank",
    "mcp-use"
  ],
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "mcp-use generate-types || exit 0",

    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true}); require('node:fs').rmSync('dist-apps',{recursive:true,force:true})\" && mcp-use build && node -e \"const fs=require('node:fs'); if(fs.existsSync('dist/public/index.html')) fs.copyFileSync('dist/public/index.html','dist/index.html');\" && npm run build:apps",
    "build:apps": "npx vite build --config apps/hero-app/vite.config.ts && npx vite build --config apps/expectation-app/vite.config.ts",

    "dev": "mcp-use dev",
    "start": "mcp-use start",

    "deploy": "mcp-use deploy",
    "vercel-build": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vercel/sandbox": "^2.0.0",
    "hono": "^4.12.22",
    "mcp-use": "latest",
    "neo4j-driver": "^6.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.0",
    "tailwindcss": "^4.2.0",
    "zod": "4.3.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
